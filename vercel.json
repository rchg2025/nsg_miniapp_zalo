{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/zalo-webhook",
      "destination": "/server/index.js"
    },
    {
      "source": "/",
      "destination": "/server/public/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/server/public/$1"
    }
  ]
}
