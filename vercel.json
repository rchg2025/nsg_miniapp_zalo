{
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "server/public/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/server/index.js"
    },
    {
      "source": "/zalo-webhook",
      "destination": "/server/index.js"
    },
    {
      "source": "/",
      "destination": "/server/public/index.html"
    },
    {
      "source": "/:match*",
      "destination": "/server/public/:match*"
    }
  ]
}
